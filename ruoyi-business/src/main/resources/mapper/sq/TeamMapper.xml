<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.sq.mapper.TeamMapper">
    <resultMap id="TeamResult" type="com.ruoyi.sq.domain.Team">
        <result property="id" column="id" />
        <result property="tname" column="tname" />
        <result property="mine" column="mine" />
        <result property="tnameuser" column="tnameuser" />
        <result property="createUser" column="create_user" />
        <result property="createDept" column="create_dept" />
        <result property="createTime" column="create_time" />
        <result property="updateUser" column="update_user" />
        <result property="updateTime" column="update_time" />
        <result property="status" column="status" />
        <result property="isDeleted" column="is_deleted" />
    </resultMap>

    <sql id="selectTeamVo">
        select `id`, `tname`, `mine`, `tnameuser`, `create_user`, `create_dept`, `create_time`, `update_user`, `update_time`, `status`, `is_deleted` from `a_team`
    </sql>

    <select id="selectTeamById" resultMap="TeamResult">
        <include refid="selectTeamVo"/> where `id` = #{id}
    </select>

    <select id="selectTeamList" resultMap="TeamResult">
        <include refid="selectTeamVo"/>
        <where>
            <if test="id != null"> and `id` = #{id}</if>
            <if test="tname != null and tname != ''"> and `tname` = #{tname}</if>
            <if test="mine != null and mine != ''"> and `mine` = #{mine}</if>
            <if test="tnameuser != null and tnameuser != ''"> and `tnameuser` = #{tnameuser}</if>
            <if test="createUser != null and createUser != ''"> and `create_user` = #{createUser}</if>
            <if test="createDept != null and createDept != ''"> and `create_dept` = #{createDept}</if>
            <if test="createTime != null"> and `create_time` = #{createTime}</if>
            <if test="updateUser != null and updateUser != ''"> and `update_user` = #{updateUser}</if>
            <if test="updateTime != null"> and `update_time` = #{updateTime}</if>
            <if test="status != null and status != ''"> and `status` = #{status}</if>
            <if test="isDeleted != null and isDeleted != ''"> and `is_deleted` = #{isDeleted}</if>
        </where>
    </select>

    <insert id="insertTeam" parameterType="com.ruoyi.sq.domain.Team" useGeneratedKeys="true" keyProperty="id">
        insert into `a_team`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">`id`,</if>
            <if test="tname != null">`tname`,</if>
            <if test="mine != null">`mine`,</if>
            <if test="tnameuser != null">`tnameuser`,</if>
            <if test="createUser != null">`create_user`,</if>
            <if test="createDept != null">`create_dept`,</if>
            <if test="createTime != null">`create_time`,</if>
            <if test="updateUser != null">`update_user`,</if>
            <if test="updateTime != null">`update_time`,</if>
            <if test="status != null">`status`,</if>
            <if test="isDeleted != null">`is_deleted`,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="tname != null">#{tname},</if>
            <if test="mine != null">#{mine},</if>
            <if test="tnameuser != null">#{tnameuser},</if>
            <if test="createUser != null">#{createUser},</if>
            <if test="createDept != null">#{createDept},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateUser != null">#{updateUser},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="status != null">#{status},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
        </trim>
    </insert>

    <update id="updateTeam" parameterType="com.ruoyi.sq.domain.Team">
        update `a_team`
        <set>
            <if test="tname != null">`tname` = #{tname},</if>
            <if test="mine != null">`mine` = #{mine},</if>
            <if test="tnameuser != null">`tnameuser` = #{tnameuser},</if>
            <if test="createUser != null">`create_user` = #{createUser},</if>
            <if test="createDept != null">`create_dept` = #{createDept},</if>
            <if test="createTime != null">`create_time` = #{createTime},</if>
            <if test="updateUser != null">`update_user` = #{updateUser},</if>
            <if test="updateTime != null">`update_time` = #{updateTime},</if>
            <if test="status != null">`status` = #{status},</if>
            <if test="isDeleted != null">`is_deleted` = #{isDeleted},</if>
        </set>
        where `id` = #{id}
    </update>
    <update id="deleteTeamByIds">
        update `a_team` set `is_deleted` = '1' where `id` in
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>

    <update id="deleteTeamById">
        update `a_team` set `is_deleted` = '1' where `id` = #{id}
    </update>

</mapper>
