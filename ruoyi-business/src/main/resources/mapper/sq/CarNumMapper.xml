<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.sq.mapper.CarNumMapper">
    <resultMap id="CarNumResult" type="com.ruoyi.sq.domain.CarNum">
        <result property="id" column="id" />
        <result property="ip" column="ip" />
        <result property="carsNum" column="cars_num" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectCarNumVo">
        select `id`, `ip`, `cars_num`, `create_time` from `a_car_num`
    </sql>

    <select id="selectById" resultMap="CarNumResult">
        <include refid="selectCarNumVo"/> where `id` = #{id}
    </select>

    <select id="selectList" resultMap="CarNumResult">
        <include refid="selectCarNumVo"/>
        <where>
            <if test="id != null"> and `id` = #{id}</if>
            <if test="ip != null and ip != ''"> and `ip` = #{ip}</if>
            <if test="carsNum != null and carsNum != ''"> and `cars_num` = #{carsNum}</if>
            <if test="createTime != null"> and `create_time` = #{createTime}</if>
        </where>
    </select>

    <select id="selectMapList" resultType="java.util.LinkedHashMap">
        <include refid="selectCarNumVo"/>
        <where>
            <if test="id != null"> and `id` = #{id}</if>
            <if test="ip != null and ip != ''"> and `ip` = #{ip}</if>
            <if test="carsNum != null and carsNum != ''"> and `cars_num` = #{carsNum}</if>
            <if test="createTime != null"> and `create_time` = #{createTime}</if>
        </where>
    </select>

    <insert id="insert" parameterType="com.ruoyi.sq.domain.CarNum" useGeneratedKeys="true" keyProperty="id">
        insert into `a_car_num`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">`id`,</if>
            <if test="ip != null">`ip`,</if>
            <if test="carsNum != null">`cars_num`,</if>
            <if test="createTime != null">`create_time`,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="ip != null">#{ip},</if>
            <if test="carsNum != null">#{carsNum},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="update" parameterType="com.ruoyi.sq.domain.CarNum">
        update `a_car_num`
        <set>
            <if test="ip != null">`ip` = #{ip},</if>
            <if test="carsNum != null">`cars_num` = #{carsNum},</if>
            <if test="createTime != null">`create_time` = #{createTime},</if>
        </set>
        where `id` = #{id}
    </update>

    <delete id="deleteByIds">
        delete from `a_car_num` where `id` in
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>

    <update id="softDeleteByIds">
        update `a_car_num` set `is_deleted` = '1' where `id` in
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
</mapper>
